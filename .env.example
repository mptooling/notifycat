# Copy to .env for local development. Do not commit .env.

# --- Server ---
ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text

# --- Database ---
# SQLite path or DSN for the slack_messages table.
# Binary default: file:./data/notifycat.db (relative to cwd).
# Docker image default: file:/app/notifycat.db.
# Uncomment and override only if you want something else.
# DATABASE_URL=file:./data/notifycat.db

# --- Mappings ---
# Path to the declarative mappings.yaml. The sibling lock file
# (mappings.lock) lives next to it, derived by swapping the .yaml/.yml
# extension for .lock. See docs/mappings.md and mappings.example.yaml.
# Binary default: ./mappings.yaml. Docker image default: /app/mappings.yaml.
# NOTIFYCAT_MAPPINGS_FILE=./mappings.yaml

# --- GitHub ---
# The "Secret" you configure on the webhook in GitHub. Required.
GITHUB_WEBHOOK_SECRET=replace-me

# --- Slack ---
# Bot token starting with "xoxb-". Required.
SLACK_BOT_TOKEN=xoxb-replace-me

# --- Reviewer suppression ---
# When true, skip Slack reactions for any review whose sender.type == "Bot"
# (Copilot, dependabot, github-actions, …). Default false. See docs/operations.md
# for the bots-vs-AI tradeoff.
NOTIFYCAT_IGNORE_AI_REVIEWS=false

# --- Reverse proxy (docker compose) ---
# Public DNS name that points at this host. Caddy uses it as the virtual-host
# name and obtains a Let's Encrypt certificate via the HTTP-01 challenge.
# Required when using compose.yaml.
DOMAIN=notifycat.example.com
# Contact email for Let's Encrypt registration (strongly recommended).
# Required when using compose.yaml — Caddy will fail to start without it.
ACME_EMAIL=ops@example.com

# --- Reactions (optional; defaults shown) ---
SLACK_REACTIONS_ENABLED=true
SLACK_REACTION_NEW_PR=large_green_circle
SLACK_REACTION_MERGED_PR=twisted_rightwards_arrows
SLACK_REACTION_CLOSED_PR=x
SLACK_REACTION_PR_APPROVED=white_check_mark
SLACK_REACTION_PR_COMMENTED=speech_balloon
SLACK_REACTION_PR_REQUEST_CHANGE=exclamation
# Distinct marker added alongside the normal reaction when a bot reviewer is NOT
# suppressed (i.e. NOTIFYCAT_IGNORE_AI_REVIEWS=false). Set empty to keep bot
# reviews indistinguishable from human ones.
SLACK_REACTION_BOT_REVIEW=robot_face
