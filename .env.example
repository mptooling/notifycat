# Secrets and infra-interpolation only. All other configuration lives in config.yaml — see config.example.yaml.
# Copy to .env for local development. Do not commit .env.

# Which webhook secret is required depends on git_provider in config.yaml: a github
# deployment needs GITHUB_WEBHOOK_SECRET, a bitbucket deployment needs
# BITBUCKET_WEBHOOK_SECRET. SLACK_BOT_TOKEN is always required. A deployment never
# needs the other provider's credentials.

# --- GitHub webhook secret ---
# The "Secret" you configure on the webhook in GitHub. Required for git_provider: github.
GITHUB_WEBHOOK_SECRET=replace-me

# --- Slack bot token ---
# Bot token starting with "xoxb-". Required.
SLACK_BOT_TOKEN=xoxb-replace-me

# --- GitHub token (optional) ---
# PAT used by notifycat-config validate and notifycat-doctor to read repo webhook config.
# Required scope: admin:repo_hook (or repo for private repos). The server does not need this.
# GITHUB_TOKEN=

# --- Bitbucket webhook secret ---
# The "Secret" you configure on the Bitbucket repository/workspace webhook.
# Required for git_provider: bitbucket. Bitbucket signs deliveries with
# X-Hub-Signature: sha256=<hmac>; an unsigned delivery (no secret configured) is rejected.
# BITBUCKET_WEBHOOK_SECRET=replace-me

# --- Bitbucket token (optional) ---
# Access token (Bearer) used by notifycat-config validate / notifycat-doctor to read
# webhook config and by path routing to read a PR's changed files — exact GITHUB_TOKEN
# degradation parity (absent: path rules inert, validation probes skip). Least-privilege
# scopes: repository + pullrequest + webhook. The server does not need this.
# BITBUCKET_TOKEN=
# Optional: pair with an email to switch to HTTP Basic with a scoped Atlassian API token
# (the Free-plan path for workspace-wildcard listing). Leave unset to use Bearer.
# BITBUCKET_AUTH_EMAIL=

# --- Slack signing secret (optional) ---
# Enables the inbound Slack interactivity endpoint (POST /webhook/slack/interactions),
# e.g. the "Start review" button. Find it under your Slack app's Basic Information →
# App Credentials → Signing Secret. When unset, notifycat stays outbound-only and the
# route is not registered.
# SLACK_SIGNING_SECRET=

# --- AI layer (optional) ---
# Model-provider API key for the optional AI layer (docs/ai.md). Required for
# ai.provider: gemini; optional for openai_compatible (keyless local endpoints).
# AI_API_KEY=

# --- Reverse proxy (docker compose) ---
# Public DNS name that points at this host. Caddy uses it as the virtual-host name and obtains a
# Let's Encrypt certificate via the HTTP-01 challenge. Required when using compose.yaml.
DOMAIN=notifycat.example.com
# Contact email for Let's Encrypt registration (strongly recommended).
# Required when using compose.yaml — Caddy will fail to start without it.
ACME_EMAIL=ops@example.com
