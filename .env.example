# Secrets and infra-interpolation only. All other configuration lives in config.yaml — see config.example.yaml.
# Copy to .env for local development. Do not commit .env.

# --- GitHub webhook secret ---
# The "Secret" you configure on the webhook in GitHub. Required.
GITHUB_WEBHOOK_SECRET=replace-me

# --- Slack bot token ---
# Bot token starting with "xoxb-". Required.
SLACK_BOT_TOKEN=xoxb-replace-me

# --- GitHub token (optional) ---
# PAT used by notifycat-config validate and notifycat-doctor to read repo webhook config.
# Required scope: admin:repo_hook (or repo for private repos). The server does not need this.
# GITHUB_TOKEN=

# --- Reverse proxy (docker compose) ---
# Public DNS name that points at this host. Caddy uses it as the virtual-host name and obtains a
# Let's Encrypt certificate via the HTTP-01 challenge. Required when using compose.yaml.
DOMAIN=notifycat.example.com
# Contact email for Let's Encrypt registration (strongly recommended).
# Required when using compose.yaml — Caddy will fail to start without it.
ACME_EMAIL=ops@example.com
