#!/bin/sh
# Notifycat host wrapper — dispatch to the setup wizard or in-container binaries.
# Run from the project directory that contains compose.yaml.
set -eu

COMPOSE_SVC=notifycat

# Restore terminal echo if the process exits while read_secret holds stty -echo.
_saved_stty=""
_restore_stty() {
  [ -n "$_saved_stty" ] && stty "$_saved_stty" 2>/dev/null || stty echo 2>/dev/null || true
}
trap _restore_stty EXIT HUP INT TERM

# ── helpers ───────────────────────────────────────────────────────────────────

die() { printf 'notifycat: error: %s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
Usage: ./notifycat <command> [args…]

Commands:
  setup           Interactive wizard — writes .env and mappings.yaml
  doctor [org/repo]
                  Run notifycat-doctor inside the running stack
  smoke           End-to-end smoke test (not yet implemented)
  up              docker compose up -d
  logs            docker compose logs -f
  down            docker compose down

Run './notifycat setup' to get started.
EOF
}

# Read a line from stdin without echoing characters.
# Result is stored in the global $_secret_val.
_secret_val=""
read_secret() {
  _saved_stty=$(stty -g 2>/dev/null) || _saved_stty=""
  stty -echo 2>/dev/null || true
  IFS= read -r _secret_val || true
  [ -n "$_saved_stty" ] && stty "$_saved_stty" 2>/dev/null || stty echo 2>/dev/null || true
  _saved_stty=""
  printf '\n'
}

# Prompt for plain text, re-prompting until the validate function returns 0.
# Result is stored in the global $_val.
_val=""
prompt_until() {
  _pu_prompt="$1"
  _pu_fn="$2"
  while true; do
    printf '%s' "$_pu_prompt"
    IFS= read -r _val || die "unexpected end of input"
    "$_pu_fn" "$_val" && return 0
    printf '  invalid input — please try again\n'
  done
}

# Prompt for a secret (no echo), re-prompting until the validate function returns 0.
# Result is stored in the global $_val.
prompt_secret_until() {
  _psu_prompt="$1"
  _psu_fn="$2"
  while true; do
    printf '%s' "$_psu_prompt"
    read_secret
    _val="$_secret_val"
    "$_psu_fn" "$_val" && return 0
    printf '  invalid input — please try again\n'
  done
}

# Validators — return 0 on success, 1 on failure.
is_nonempty() { [ -n "$1" ]; }
is_domain()   { printf '%s' "$1" | grep -qE '^[a-zA-Z0-9]([a-zA-Z0-9.-]*[a-zA-Z0-9])?\.[a-zA-Z]{2,}$'; }
is_email()    { printf '%s' "$1" | grep -qE '^[^@]+@[^@]+\.[^@]+$'; }
is_channel()  { printf '%s' "$1" | grep -qE '^[CGD][A-Z0-9]{2,}$'; }
is_org()      { printf '%s' "$1" | grep -qE '^[A-Za-z0-9_.-]+$'; }
is_repos() {
  _ir_v=$(printf '%s' "$1" | tr -d ' ')
  [ "$_ir_v" = "*" ] && return 0
  [ -z "$_ir_v" ] && return 1
  # Every comma-separated token must be a bare repo name (no slash, no space).
  printf '%s,' "$_ir_v" | grep -qE '^([A-Za-z0-9_.-]+,)+$'
}

# y/N confirmation — returns 0 for yes.
confirm() {
  printf '%s [y/N] ' "$1"
  IFS= read -r _confirm_ans || _confirm_ans=""
  case "$_confirm_ans" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

# Write .env by processing .env.example and substituting the four wizard values.
# Uses outer variables: domain, acme_email, webhook_secret, slack_token.
write_env() {
  while IFS= read -r _we_line; do
    case "$_we_line" in
      DOMAIN=*)                printf 'DOMAIN=%s\n'                "$domain"         ;;
      ACME_EMAIL=*)            printf 'ACME_EMAIL=%s\n'            "$acme_email"     ;;
      GITHUB_WEBHOOK_SECRET=*) printf 'GITHUB_WEBHOOK_SECRET=%s\n' "$webhook_secret" ;;
      SLACK_BOT_TOKEN=*)       printf 'SLACK_BOT_TOKEN=%s\n'       "$slack_token"    ;;
      *)                       printf '%s\n'                        "$_we_line"       ;;
    esac
  done < .env.example
}

# Write a starter mappings.yaml.
# Uses outer variables: gh_org, gh_repos, slack_channel.
write_mappings() {
  printf '# Generated by ./notifycat setup — edit freely.\n'
  printf '# See mappings.example.yaml for the full format reference.\n'
  printf 'mappings:\n'
  printf '  %s:\n' "$gh_org"
  printf '    channel: %s\n' "$slack_channel"
  printf '    mentions:\n'
  printf '      - "<!channel>"\n'
  if [ "$gh_repos" = "*" ]; then
    printf '    repositories: "*"\n'
  else
    printf '    repositories:\n'
    _wm_old_ifs="$IFS"
    IFS=','
    for _wm_repo in $gh_repos; do
      _wm_repo=$(printf '%s' "$_wm_repo" | tr -d ' ')
      [ -n "$_wm_repo" ] && printf '      - %s\n' "$_wm_repo"
    done
    IFS="$_wm_old_ifs"
  fi
}

# ── subcommands ───────────────────────────────────────────────────────────────

cmd_setup() {
  [ -f .env.example ] || die ".env.example not found — run this from the project root"
  [ -f compose.yaml ]  || die "compose.yaml not found — run this from the project root"

  printf '\n=== Notifycat Setup Wizard ===\n\n'
  printf 'This wizard writes .env and a starter mappings.yaml.\n'
  printf 'Existing files will not be overwritten without your confirmation.\n\n'

  # ── Step 1: server configuration ──────────────────────────────────────────
  printf '── Step 1 of 3: Server configuration ──────────────────────────────\n\n'

  prompt_until 'Public domain (e.g. notifycat.acme.com): ' is_domain
  domain="$_val"

  prompt_until "ACME / Let's Encrypt contact email: " is_email
  acme_email="$_val"

  prompt_secret_until 'GitHub webhook secret (hidden): ' is_nonempty
  webhook_secret="$_val"

  prompt_secret_until 'Slack bot token (xoxb-…, hidden): ' is_nonempty
  slack_token="$_val"

  # ── Step 2: starter mapping ────────────────────────────────────────────────
  printf '\n── Step 2 of 3: Starter Slack mapping ─────────────────────────────\n\n'
  printf 'You can add more entries to mappings.yaml at any time.\n\n'

  prompt_until 'GitHub org name: ' is_org
  gh_org="$_val"

  prompt_until 'Repositories (* for all, or comma-separated names like api,web): ' is_repos
  gh_repos="$_val"

  prompt_until 'Slack channel ID (starts with C, G, or D — e.g. C0123ABCDE): ' is_channel
  slack_channel="$_val"

  # ── Step 3: write files ────────────────────────────────────────────────────
  printf '\n── Step 3 of 3: Writing files ──────────────────────────────────────\n\n'

  _setup_write_env=1
  if [ -f .env ]; then
    confirm '.env already exists — overwrite?' || _setup_write_env=0
  fi
  if [ "$_setup_write_env" = "1" ]; then
    write_env > .env
    chmod 0600 .env
    printf '  .env written (0600)\n'
  else
    printf '  .env skipped\n'
  fi

  _setup_write_map=1
  if [ -f mappings.yaml ]; then
    confirm 'mappings.yaml already exists — overwrite?' || _setup_write_map=0
  fi
  if [ "$_setup_write_map" = "1" ]; then
    write_mappings > mappings.yaml
    printf '  mappings.yaml written\n'
  else
    printf '  mappings.yaml skipped\n'
  fi

  printf '\n── Done — next steps ───────────────────────────────────────────────\n\n'
  printf '  1. Start the stack:\n\n'
  printf '       docker compose up -d\n\n'
  printf '  2. Register a webhook on each GitHub repo in %s:\n\n' "$gh_org"
  printf '       Payload URL:  https://%s/webhook/github\n' "$domain"
  printf '       Content type: application/json\n'
  printf '       Secret:       (the webhook secret you entered above)\n'
  printf '       Events:       Pull requests, Pull request reviews\n\n'
  printf '  3. Verify the setup:\n\n'
  printf '       ./notifycat doctor %s/<repo>\n\n' "$gh_org"
}

cmd_doctor() {
  docker compose run --rm "$COMPOSE_SVC" notifycat-doctor "$@"
}

cmd_smoke() {
  die "smoke is not yet implemented — see https://github.com/mptooling/notifycat/issues/45"
}

# ── dispatch ──────────────────────────────────────────────────────────────────

cmd="${1:-}"
[ -n "$cmd" ] || { usage; exit 1; }
shift

case "$cmd" in
  setup)     cmd_setup ;;
  doctor)    cmd_doctor "$@" ;;
  smoke)     cmd_smoke "$@" ;;
  up)        docker compose up -d "$@" ;;
  logs)      docker compose logs -f "$@" ;;
  down)      docker compose down "$@" ;;
  -h|--help) usage ;;
  *)         printf 'notifycat: unknown command: %s\n' "$cmd" >&2; usage >&2; exit 1 ;;
esac
